# ───── LINE Messaging API ─────
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# 管理者/テスト用（任意）
LINE_USER_ID=

# ───── Google OAuth / Gmail / Calendar ─────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ───── Anthropic ─────
ANTHROPIC_API_KEY=

# ───── Runtime ─────
PORT=3000
DB_PATH=./data/secretary.db
TZ=Asia/Tokyo
NODE_ENV=development

# ───── Stripe 決済 ─────
# 未設定なら決済系コマンド（プラン/解約/領収書）は「準備中です」応答になる
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripeダッシュボードで Product + Price (月額/JPY) 作成後の Price ID
STRIPE_PRICE_LITE=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PRO=

# ───── 課金ページのベースURL ─────
# Stripe Checkout の success/cancel URL、Customer Portal の return_url に使う
APP_BASE_URL=https://ai-hisho.net

# ───── 管理画面 (/admin) Basic 認証パスワード ─────
# 未設定なら /admin は 503 を返す
ADMIN_PASSWORD=

# ───── テスト用エンドポイント有効化 ─────
# true にすると /test が LINE 署名検証なしで使えるようになる
ENABLE_TEST_ENDPOINT=false
